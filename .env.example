# Telegram Bot Token (obtenha em @BotFather)
TELEGRAM_TOKEN=seu_token_aqui

# Groq API Key (obtenha em https://console.groq.com)
GROQ_API_KEY=sua_chave_aqui

# Replicate API Token (opcional — para geração de vídeo/imagem)
REPLICATE_API_TOKEN=

# ── Google OAuth2 (para /conectar — Gmail, Drive, Calendar) ──
# 1. Acesse https://console.cloud.google.com/
# 2. Crie um projeto > APIs & Services > Credentials
# 3. Crie "OAuth 2.0 Client ID" (tipo: Web application)
# 4. Adicione URI de redirecionamento: https://SEU_DOMINIO/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://SEU_DOMINIO/auth/google/callback

# URL base do serviço (usado para gerar links OAuth)
BASE_URL=https://SEU_DOMINIO

# ── Google (modo legado — token estático, sem /conectar) ──
# GOOGLE_ACCESS_TOKEN=
# GOOGLE_REFRESH_TOKEN=
